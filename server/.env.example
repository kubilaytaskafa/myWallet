# Uygulama Ayarları
APP_NAME=My-Wallet-API v1.0.0
HTTP_PORT=5000
APP_ENV=DEV

# Veritabanı (MySQL)
# Örnek: kullanici:sifre@tcp(host:port)/veritabani?charset=utf8mb4&parseTime=True&loc=Local
DB_DSN=kullanici:sifre@tcp(127.0.0.1:3306)/mywallet_db?charset=utf8mb4&parseTime=True&loc=Local

# JWT Gizli Anahtarı — EN AZ 32 karakter, tamamen rastgele bir değer kullanın
# Öneri (Linux/Mac): openssl rand -hex 32
SECRET_KEY=BURAYA_EN_AZ_32_KARAKTER_RASTGELE_BIR_DEGER_KOY

# CORS — Production'da kendi domain'ini yaz (virgülle ayır)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── İlk Admin Kurulumu (Opsiyonel) ───────────────────────────────────────────
# Aşağıdaki değerler tanımlandığında uygulama ilk açılışta bu bilgilerle
# bir admin hesabı oluşturur. Hesap oluştuktan sonra bu satırları kaldırabilirsiniz.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=
SEED_ADMIN_SURNAME=
